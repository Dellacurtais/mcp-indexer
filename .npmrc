# The AWS SDK v3 (optional dep, used by `code-context enrich`) pulls a deep
# transitive tree (tslib, @smithy/*, @aws-crypto/*) that pnpm's strict symlinked
# layout fails to resolve at runtime ("Cannot find module 'tslib'"). Hoisting to
# a flat node_modules — like npm/yarn — fixes it. This is an application (not a
# library), so the looser layout is fine.
shamefully-hoist=true
