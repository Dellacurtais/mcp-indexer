# code-context — optional configuration.
#
# Copy to `.env` in the directory you run the CLI from, OR to the GLOBAL file
# `~/.code-context/.env` (loaded no matter where you run the CLI — best for creds).
# Precedence: real shell env  >  ./.env  >  ~/.code-context/.env
#
# Everything here is optional; the local index/serve/search work with none of it.

# ── Optional LLM enrichment ( `code-context enrich`, AWS Bedrock ) ──────────────
# Turn it on:
# CODE_CONTEXT_ANALYSIS=bedrock          # or `mock` to preview offline (no AWS, no cost)

# AWS credentials — or use ~/.aws/credentials, SSO, or an instance/ECS role instead.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Model (default: amazon.titan-text-express-v1). For inference-profile-only models
# (Nova, newer Claude) either pass the full id here, or set the prefix flag below
# (equivalent to the CLI `--inference`, which prepends us./eu./apac. by region).
# CODE_CONTEXT_ANALYSIS_MODEL=amazon.nova-lite-v1:0
# CODE_CONTEXT_ANALYSIS_INFERENCE=1

# Max USD spent per enrich run (the CLI `--budget` overrides this).
# MCP_INDEX_BUDGET=1.00

# ── Optional: Bedrock embeddings instead of local ONNX ( PAID; needs re-index ) ─
# Replaces the local 384-dim ONNX model with AWS Titan (1024-dim). Costs per token
# (indexing + every query embeds), loses offline. Reuses the AWS_* creds above.
# Switching dimension REQUIRES a fresh index (delete ~/.code-context/index.db or set
# a new MCP_DATA_DIR, then `code-context index <repo>`).
# MCP_EMBEDDINGS=bedrock
# CODE_CONTEXT_EMBED_MODEL=amazon.titan-embed-text-v2:0    # or amazon.titan-embed-text-v1 (1536-dim)

# ── Optional: Bedrock reranker ( higher search precision ) ──────────────────────
# Replaces the local ONNX cross-encoder with a Bedrock rerank model. Runs on EVERY
# search, so it adds network latency + a per-query Bedrock cost — opt in only if you
# want the extra precision. Reuses the AWS_* credentials above.
# CODE_CONTEXT_RERANK=bedrock
# CODE_CONTEXT_RERANK_MODEL=amazon.rerank-v1:0       # or cohere.rerank-v3-5:0, or a full model ARN

# ── Data dir (where index.db and this global .env live) ─────────────────────────
# MCP_DATA_DIR=
