# code-context — optional configuration.
#
# Copy to `.env` in the directory you run the CLI from, OR to the GLOBAL file
# `~/.code-context/.env` (loaded no matter where you run the CLI — best for creds).
# Precedence: real shell env  >  ./.env  >  ~/.code-context/.env
#
# Everything here is optional; the local index/serve/search work with none of it.

# ── Optional LLM enrichment ( `code-context enrich` ) ──────────────────────────
# Backend for enrich (and the explorer below). `bedrock` uses the AWS creds below;
# `copilot` uses your GitHub Copilot subscription (run `code-context login copilot`
# once — ~zero per-token cost); `mock` previews offline. Set it in the dashboard
# (`code-context ui`) or here.
# CODE_CONTEXT_ANALYSIS=bedrock          # bedrock | copilot | mock

# AWS credentials — or use ~/.aws/credentials, SSO, or an instance/ECS role instead.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Model (default: amazon.titan-text-express-v1). For inference-profile-only models
# (Nova, newer Claude) either pass the full id here, or set the prefix flag below
# (equivalent to the CLI `--inference`, which prepends us./eu./apac. by region).
# CODE_CONTEXT_ANALYSIS_MODEL=amazon.nova-lite-v1:0
# CODE_CONTEXT_ANALYSIS_INFERENCE=1

# Max USD spent per enrich run (the CLI `--budget` overrides this).
# MCP_INDEX_BUDGET=1.00

# ── Optional: explorer sub-agent ( the `agent_explore` MCP tool ) ───────────────
# Lets Copilot delegate "find/understand/where" investigations to a CHEAP local
# model that runs a no-turn-limit read-only loop and returns a full markdown report
# — so the expensive model spends no tokens exploring. Defaults to the enrich
# backend above; override the provider/model here (set it in the dashboard too).
# CODE_CONTEXT_EXPLORER_PROVIDER=bedrock     # bedrock | copilot
# CODE_CONTEXT_EXPLORER_MODEL=amazon.nova-lite-v1:0   # cheap + tool-capable (Nova / a small Copilot model)
# CODE_CONTEXT_EXPLORER_INFERENCE=1          # for Bedrock inference-profile-only ids
# Safety bounds (optional): MCP_EXPLORE_MAX_CALLS (40), MCP_EXPLORE_BUDGET (0.50),
# MCP_EXPLORE_TIMEOUT_MS (180000). explore runs as a background job: each
# agent_explore / agent_explore_result call blocks up to MCP_EXPLORE_POLL_MS (20000) waiting
# for the report, then asks the agent to call agent_explore_result again. Keep it UNDER
# your MCP client's per-call timeout; raise it (if your client allows) for fewer polls.
# CODE_CONTEXT_EXPLORER_MODEL prefer a FAST model (e.g. gpt-4o-mini) — fewer turns
# = finishes sooner = fewer polls.

# ── Optional: exec tool ( OPT-IN, runs shell commands ) ─────────────────────────
# Adds exec_command / write_stdin / list_sessions ON TOP of the read-only tools
# (never replaces them) so the agent can run commands in the project root. Off by
# default — enable per the dashboard toggle or here. Use only in trusted projects.
# MCP_EXEC=1

# ── Copilot editor identity (advanced — only if GitHub changes the requirements) ─
# Public Copilot client identifiers the API requires; overridable for forward-compat.
# CODE_CONTEXT_COPILOT_CLIENT_ID=
# CODE_CONTEXT_COPILOT_INTEGRATION_ID=
# CODE_CONTEXT_COPILOT_EDITOR_VERSION=

# ── Optional: Bedrock embeddings instead of local ONNX ( PAID; needs re-index ) ─
# Replaces the local 384-dim ONNX model with AWS Titan (1024-dim). Costs per token
# (indexing + every query embeds), loses offline. Reuses the AWS_* creds above.
# Switching dimension REQUIRES a fresh index (delete ~/.code-context/index.db or set
# a new MCP_DATA_DIR, then `code-context index <repo>`).
# MCP_EMBEDDINGS=bedrock
# CODE_CONTEXT_EMBED_MODEL=amazon.titan-embed-text-v2:0    # or amazon.titan-embed-text-v1 (1536-dim)

# ── Optional: Bedrock reranker ( higher search precision ) ──────────────────────
# Replaces the local ONNX cross-encoder with a Bedrock rerank model. Runs on EVERY
# search, so it adds network latency + a per-query Bedrock cost — opt in only if you
# want the extra precision. Reuses the AWS_* credentials above.
# CODE_CONTEXT_RERANK=bedrock
# CODE_CONTEXT_RERANK_MODEL=amazon.rerank-v1:0       # or cohere.rerank-v3-5:0, or a full model ARN
#
# Reranking ALSO uses a local ONNX model (bge-reranker-base) by default — separate
# from embeddings. For a fully NO-ONNX setup (e.g. with Bedrock embeddings), disable
# the local reranker — search falls back to RRF ordering (slightly lower precision):
# CODE_CONTEXT_RERANK=none

# ── Data dir (where index.db and this global .env live) ─────────────────────────
# MCP_DATA_DIR=
